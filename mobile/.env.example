# Copy this file to .env and fill in the values from Firebase and Google Cloud.

EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_google_oauth_client_id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_google_oauth_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_google_oauth_client_id_for_com_anonymous_luminest
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_google_oauth_client_id

# Use your computer IP when testing on a physical phone.
EXPO_PUBLIC_API_URL=http://192.168.0.100:4000
